# PostgreSQL Configuration
# For local host development, use localhost. For docker compose, use postgres.
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/atlas_db

# Redis Configuration
# For local host development, use localhost. For docker compose, use redis.
REDIS_URL=redis://localhost:6379/0

# JWT Security
# Run `openssl rand -hex 32` or similar to generate a secure secret key
JWT_SECRET=super_secret_jwt_key_for_local_development_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Logging Config
LOG_LEVEL=info

# API Settings
CORS_ORIGINS=["http://localhost:3000"]

# OpenAI API Key (Placeholder for future phases)
OPENAI_API_KEY=
